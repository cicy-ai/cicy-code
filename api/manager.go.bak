package main

import (
	"context"
	"database/sql"
	"encoding/json"
	"fmt"
	"log"
	"net/http"
	"os"
	"os/exec"
	"path/filepath"
	"strings"
	"sync"
	"time"

	_ "github.com/go-sql-driver/mysql"
	"github.com/gorilla/websocket"
)

var (
	db          *sql.DB
	instances   = make(map[string]*Instance)
	instancesMu sync.RWMutex
	portPool    = NewPortPool(15100, 15300)
	upgrader    = websocket.Upgrader{CheckOrigin: func(r *http.Request) bool { return true }}
)

type Instance struct {
	PaneID string
	Port   int
	Cmd    *exec.Cmd
}

type PortPool struct {
	start int
	end   int
	used  map[int]bool
	mu    sync.Mutex
}

func NewPortPool(start, end int) *PortPool {
	return &PortPool{start: start, end: end, used: make(map[int]bool)}
}

func (p *PortPool) Allocate() int {
	p.mu.Lock()
	defer p.mu.Unlock()
	for port := p.start; port <= p.end; port++ {
		if !p.used[port] {
			p.used[port] = true
			return port
		}
	}
	return 0
}

func (p *PortPool) Release(port int) {
	p.mu.Lock()
	defer p.mu.Unlock()
	delete(p.used, port)
}

func verifyToken(token string) bool {
	home, _ := os.UserHomeDir()
	data, _ := os.ReadFile(filepath.Join(home, "global.json"))
	var config map[string]interface{}
	json.Unmarshal(data, &config)
	apiToken, ok := config["api_token"].(string)
	return ok && apiToken == token
}

func authMiddleware(next http.HandlerFunc) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		auth := r.Header.Get("Authorization")
		if !strings.HasPrefix(auth, "Bearer ") || !verifyToken(strings.TrimPrefix(auth, "Bearer ")) {
			http.Error(w, "unauthorized", 401)
			return
		}
		next(w, r)
	}
}

func corsMiddleware(next http.HandlerFunc) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		origin := r.Header.Get("Origin")
		if origin != "" {
			w.Header().Set("Access-Control-Allow-Origin", origin)
			w.Header().Set("Access-Control-Allow-Credentials", "true")
			w.Header().Set("Access-Control-Allow-Methods", "GET, POST, PATCH, DELETE, OPTIONS")
			w.Header().Set("Access-Control-Allow-Headers", "Authorization, Content-Type")
		}
		if r.Method == "OPTIONS" {
			w.WriteHeader(204)
			return
		}
		next(w, r)
	}
}

func startInstance(paneID, token string) error {
	instancesMu.Lock()
	defer instancesMu.Unlock()

	if _, exists := instances[paneID]; exists {
		return nil
	}

	port := portPool.Allocate()
	if port == 0 {
		return fmt.Errorf("no available ports")
	}

	cmd := exec.Command("./ttyd-go", "-p", fmt.Sprintf("%d", port), "-c", fmt.Sprintf("user:%s", token), "tmux", "attach", "-t", paneID)
	cmd.Dir = "/home/w3c_offical/projects/ai-workers/ttyd-go"
	
	if err := cmd.Start(); err != nil {
		portPool.Release(port)
		return err
	}

	instances[paneID] = &Instance{PaneID: paneID, Port: port, Cmd: cmd}
	
	// Save to DB
	_, err := db.Exec("INSERT INTO ttyd_config (pane_id, ttyd_port, created_at, updated_at) VALUES (?, ?, NOW(), NOW()) ON DUPLICATE KEY UPDATE ttyd_port=?, updated_at=NOW()", paneID, port, port)
	return err
}

func stopInstance(paneID string) error {
	instancesMu.Lock()
	defer instancesMu.Unlock()

	inst, exists := instances[paneID]
	if !exists {
		return fmt.Errorf("instance not found")
	}

	inst.Cmd.Process.Kill()
	portPool.Release(inst.Port)
	delete(instances, paneID)
	return nil
}

func getPort(paneID string) (int, error) {
	instancesMu.RLock()
	defer instancesMu.RUnlock()

	inst, exists := instances[paneID]
	if !exists {
		return 0, fmt.Errorf("instance not found")
	}
	return inst.Port, nil
}

func handleListPanes(w http.ResponseWriter, r *http.Request) {
	rows, err := db.Query("SELECT pane_id, ttyd_port, title, workspace FROM ttyd_config")
	if err != nil {
		http.Error(w, err.Error(), 500)
		return
	}
	defer rows.Close()

	var panes []map[string]interface{}
	for rows.Next() {
		var paneID, title, workspace string
		var port int
		rows.Scan(&paneID, &port, &title, &workspace)
		panes = append(panes, map[string]interface{}{
			"pane_id":   paneID,
			"port":      port,
			"title":     title,
			"workspace": workspace,
		})
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"panes": panes})
}

func handleCreatePane(w http.ResponseWriter, r *http.Request) {
	var req struct {
		WinName    string `json:"win_name"`
		Workspace  string `json:"workspace"`
		InitScript string `json:"init_script"`
		Title      string `json:"title"`
	}
	json.NewDecoder(r.Body).Decode(&req)

	paneID := req.WinName
	if !strings.Contains(paneID, ":") {
		paneID = paneID + ":main.0"
	}
	
	token := strings.TrimPrefix(r.Header.Get("Authorization"), "Bearer ")

	// Create tmux session
	session := strings.Split(paneID, ":")[0]
	workspace := req.Workspace
	if workspace == "" {
		workspace = "~"
	}
	
	exec.Command("tmux", "new-session", "-d", "-s", session, "-n", "main", "-c", workspace).Run()
	time.Sleep(100 * time.Millisecond)

	if err := startInstance(paneID, token); err != nil {
		http.Error(w, err.Error(), 500)
		return
	}

	// Save to DB
	db.Exec("INSERT INTO ttyd_config (pane_id, title, workspace, init_script, created_at, updated_at) VALUES (?, ?, ?, ?, NOW(), NOW()) ON DUPLICATE KEY UPDATE title=?, workspace=?, init_script=?, updated_at=NOW()",
		paneID, req.Title, req.Workspace, req.InitScript, req.Title, req.Workspace, req.InitScript)

	// Run init script
	if req.InitScript != "" {
		for _, line := range strings.Split(req.InitScript, "\n") {
			line = strings.TrimSpace(line)
			if line != "" {
				exec.Command("tmux", "send-keys", "-t", paneID, line, "Enter").Run()
				time.Sleep(100 * time.Millisecond)
			}
		}
	}

	port, _ := getPort(paneID)
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"pane_id": paneID, "port": port})
}

func handleRestartPane(w http.ResponseWriter, r *http.Request) {
	paneID := strings.TrimPrefix(r.URL.Path, "/api/tmux/panes/")
	paneID = strings.TrimSuffix(paneID, "/restart")
	token := strings.TrimPrefix(r.Header.Get("Authorization"), "Bearer ")

	stopInstance(paneID)
	time.Sleep(500 * time.Millisecond)
	
	if err := startInstance(paneID, token); err != nil {
		http.Error(w, err.Error(), 500)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"status": "restarted"})
}

func handleDeletePane(w http.ResponseWriter, r *http.Request) {
	paneID := strings.TrimPrefix(r.URL.Path, "/api/tmux/panes/")
	
	stopInstance(paneID)
	
	// Kill tmux session
	session := strings.Split(paneID, ":")[0]
	exec.Command("tmux", "kill-session", "-t", session).Run()
	
	// Delete from DB
	db.Exec("DELETE FROM ttyd_config WHERE pane_id=?", paneID)

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"status": "deleted"})
}

func handleSendKeys(w http.ResponseWriter, r *http.Request) {
	var req struct {
		PaneID string `json:"pane_id"`
		WinID  string `json:"win_id"`
		Text   string `json:"text"`
		Keys   string `json:"keys"`
	}
	json.NewDecoder(r.Body).Decode(&req)

	target := req.PaneID
	if target == "" {
		target = req.WinID
	}

	if req.Text != "" {
		exec.Command("tmux", "send-keys", "-t", target, req.Text, "Enter").Run()
	} else if req.Keys != "" {
		exec.Command("tmux", "send-keys", "-t", target, req.Keys).Run()
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"status": "sent"})
}

func handleGetPane(w http.ResponseWriter, r *http.Request) {
	paneID := strings.TrimPrefix(r.URL.Path, "/api/tmux/panes/")
	var title, workspace sql.NullString
	var port int
	err := db.QueryRow("SELECT ttyd_port, title, workspace FROM ttyd_config WHERE pane_id=?", paneID).Scan(&port, &title, &workspace)
	w.Header().Set("Content-Type", "application/json")
	if err != nil {
		json.NewEncoder(w).Encode(map[string]interface{}{"pane_id": paneID})
		return
	}
	json.NewEncoder(w).Encode(map[string]interface{}{"pane_id": paneID, "port": port, "title": title.String, "workspace": workspace.String})
}

func handleUpdatePane(w http.ResponseWriter, r *http.Request) {
	paneID := strings.TrimPrefix(r.URL.Path, "/api/tmux/panes/")
	var req map[string]interface{}
	json.NewDecoder(r.Body).Decode(&req)
	if t, ok := req["title"].(string); ok {
		db.Exec("UPDATE ttyd_config SET title=?, updated_at=NOW() WHERE pane_id=?", t, paneID)
	}
	if ws, ok := req["workspace"].(string); ok {
		db.Exec("UPDATE ttyd_config SET workspace=?, updated_at=NOW() WHERE pane_id=?", ws, paneID)
	}
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"status": "updated"})
}

func handleCapturePane(w http.ResponseWriter, r *http.Request) {
	var req struct {
		PaneID string `json:"pane_id"`
		Lines  int    `json:"lines"`
		Start  int    `json:"start"`
		End    int    `json:"end"`
	}
	json.NewDecoder(r.Body).Decode(&req)

	if req.Lines > 0 {
		req.Start = -req.Lines
		req.End = -1
	} else if req.Start == 0 {
		req.Start = -100
		req.End = -1
	}

	cmd := exec.Command("tmux", "capture-pane", "-t", req.PaneID, "-p", "-S", fmt.Sprintf("%d", req.Start), "-E", fmt.Sprintf("%d", req.End))
	output, _ := cmd.Output()

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"pane_id": req.PaneID, "output": string(output)})
}

func handleTree(w http.ResponseWriter, r *http.Request) {
	cmd := exec.Command("tmux", "list-sessions", "-F", "#{session_name}")
	output, err := cmd.Output()
	if err != nil {
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"sessions": []string{}})
		return
	}

	sessions := []map[string]interface{}{}
	for _, line := range strings.Split(strings.TrimSpace(string(output)), "\n") {
		if line == "" {
			continue
		}
		sessions = append(sessions, map[string]interface{}{"name": line})
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"sessions": sessions})
}

func handleStatus(w http.ResponseWriter, r *http.Request) {
	rows, err := db.Query("SELECT pane_id, ttyd_port, title FROM ttyd_config LIMIT 10")
	if err != nil {
		http.Error(w, err.Error(), 500)
		return
	}
	defer rows.Close()

	var panes []map[string]interface{}
	for rows.Next() {
		var paneID, title string
		var port int
		rows.Scan(&paneID, &port, &title)
		
		// Check if ttyd-go is running
		running := false
		instancesMu.RLock()
		if _, exists := instances[paneID]; exists {
			running = true
		}
		instancesMu.RUnlock()

		panes = append(panes, map[string]interface{}{
			"pane_id": paneID,
			"port":    port,
			"title":   title,
			"running": running,
		})
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"panes": panes, "total": len(panes)})
}

func handleSendWait(w http.ResponseWriter, r *http.Request) {
	var req struct {
		Target     string `json:"target"`
		Text       string `json:"text"`
		PromptType string `json:"prompt_type"`
		Timeout    int    `json:"timeout"`
	}
	json.NewDecoder(r.Body).Decode(&req)

	if req.PromptType == "" {
		req.PromptType = "kiro-cli"
	}
	if req.Timeout == 0 {
		req.Timeout = 60
	}
	if req.Timeout > 120 {
		req.Timeout = 120
	}

	paneID := req.Target
	if !strings.Contains(paneID, ":") && strings.HasPrefix(paneID, "w-") {
		paneID = paneID + ":main.0"
	}

	// Send command
	exec.Command("tmux", "send-keys", "-t", paneID, req.Text, "Enter").Run()

	// Wait for prompt
	start := time.Now()
	for time.Since(start) < time.Duration(req.Timeout)*time.Second {
		time.Sleep(time.Second)
		
		cmd := exec.Command("tmux", "capture-pane", "-t", paneID, "-p", "-S", "-50")
		output, err := cmd.Output()
		if err != nil {
			continue
		}

		lines := strings.Split(string(output), "\n")
		if len(lines) == 0 {
			continue
		}

		// Find last non-empty line
		lastLine := ""
		for i := len(lines) - 1; i >= 0; i-- {
			trimmed := strings.TrimSpace(lines[i])
			if trimmed != "" {
				lastLine = trimmed
				break
			}
		}
		
		if lastLine == "" {
			continue
		}
		
		// Check for prompt patterns
		hasPrompt := false
		if req.PromptType == "kiro-cli" {
			// Match: "100% >" or "50% >" etc
			hasPrompt = strings.Contains(lastLine, "%") && strings.HasSuffix(lastLine, ">")
		} else if req.PromptType == "bash" {
			// Match: "test-bash$" or "w-20083 $" or similar
			hasPrompt = strings.HasSuffix(lastLine, "$")
		}

		if hasPrompt {
			// Extract new output
			newLines := []string{}
			foundCommand := false
			for _, line := range lines {
				if !foundCommand && strings.Contains(line, req.Text) {
					foundCommand = true
					continue
				}
				if foundCommand {
					newLines = append(newLines, line)
				}
			}

			answer := strings.Join(newLines, "\n")
			answer = strings.TrimSpace(answer)

			w.Header().Set("Content-Type", "application/json")
			json.NewEncoder(w).Encode(map[string]interface{}{
				"success":  true,
				"pane_id":  paneID,
				"question": req.Text,
				"answer":   answer,
			})
			return
		}
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"success": false,
		"error":   fmt.Sprintf("timeout after %ds", req.Timeout),
	})
}

func handleMouseToggle(w http.ResponseWriter, r *http.Request) {
	action := strings.TrimPrefix(r.URL.Path, "/api/tmux/mouse/")
	
	if action != "on" && action != "off" {
		http.Error(w, "action must be on or off", 400)
		return
	}

	exec.Command("tmux", "set", "-g", "mouse", action).Run()

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"success":    true,
		"mouse_mode": action,
	})
}

func handleMouseStatus(w http.ResponseWriter, r *http.Request) {
	cmd := exec.Command("tmux", "show-options", "-g", "mouse")
	output, _ := cmd.Output()
	
	isOn := strings.Contains(string(output), "on")
	mode := "off"
	if isOn {
		mode = "on"
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"success":    true,
		"mouse_mode": mode,
	})
}

func handleWSProxy(w http.ResponseWriter, r *http.Request) {
	paneID := strings.TrimPrefix(r.URL.Path, "/api/ws/")

	port, err := getPort(paneID)
	if err != nil {
		http.Error(w, "pane not found", 404)
		return
	}

	clientConn, err := upgrader.Upgrade(w, r, nil)
	if err != nil {
		return
	}
	defer clientConn.Close()

	ttydConn, _, err := websocket.DefaultDialer.Dial(fmt.Sprintf("ws://localhost:%d/ws", port), nil)
	if err != nil {
		return
	}
	defer ttydConn.Close()

	ctx, cancel := context.WithCancel(context.Background())
	defer cancel()

	go func() {
		for {
			msgType, msg, err := ttydConn.ReadMessage()
			if err != nil {
				cancel()
				return
			}
			if err := clientConn.WriteMessage(msgType, msg); err != nil {
				cancel()
				return
			}
		}
	}()

	for {
		select {
		case <-ctx.Done():
			return
		default:
			msgType, msg, err := clientConn.ReadMessage()
			if err != nil {
				return
			}
			if err := ttydConn.WriteMessage(msgType, msg); err != nil {
				return
			}
		}
	}
}

func main() {
	var err error
	dsn := os.Getenv("MYSQL_DSN")
	if dsn == "" {
		dsn = "root:@tcp(localhost:3306)/ai_workers"
	}
	db, err = sql.Open("mysql", dsn)
	if err != nil {
		log.Fatal(err)
	}
	defer db.Close()

	// Health
	http.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
		if r.URL.Path != "/" {
			http.NotFound(w, r)
			return
		}
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"service": "ttyd-manager", "version": "0.1.0"})
	})

	// Auth
	http.HandleFunc("/api/auth/verify-token", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"valid": true})
	})))
	http.HandleFunc("/api/auth/verify", corsMiddleware(func(w http.ResponseWriter, r *http.Request) {
		auth := r.Header.Get("Authorization")
		valid := strings.HasPrefix(auth, "Bearer ") && verifyToken(strings.TrimPrefix(auth, "Bearer "))
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"valid": valid})
	}))

	// Panes
	http.HandleFunc("/api/tmux/panes", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		if r.Method == "GET" {
			handleListPanes(w, r)
		} else {
			http.Error(w, "method not allowed", 405)
		}
	})))
	http.HandleFunc("/api/tmux/list", corsMiddleware(authMiddleware(handleListPanes)))
	http.HandleFunc("/api/tmux/create", corsMiddleware(authMiddleware(handleCreatePane)))
	http.HandleFunc("/api/tmux/send", corsMiddleware(authMiddleware(handleSendKeys)))
	http.HandleFunc("/api/tmux/send-keys", corsMiddleware(authMiddleware(handleSendKeys)))
	http.HandleFunc("/api/tmux/send_wait", corsMiddleware(authMiddleware(handleSendWait)))
	http.HandleFunc("/api/tmux/capture_pane", corsMiddleware(authMiddleware(handleCapturePane)))
	http.HandleFunc("/api/tmux/tree", corsMiddleware(authMiddleware(handleTree)))
	http.HandleFunc("/api/tmux/status", corsMiddleware(authMiddleware(handleStatus)))

	// Mouse
	http.HandleFunc("/api/tmux/mouse/on", corsMiddleware(authMiddleware(handleMouseToggle)))
	http.HandleFunc("/api/tmux/mouse/off", corsMiddleware(authMiddleware(handleMouseToggle)))
	http.HandleFunc("/api/tmux/mouse/status", corsMiddleware(authMiddleware(handleMouseStatus)))

	// TTYD status
	http.HandleFunc("/api/tmux/ttyd/status/", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		paneID := strings.TrimPrefix(r.URL.Path, "/api/tmux/ttyd/status/")
		instancesMu.RLock()
		inst, exists := instances[paneID]
		instancesMu.RUnlock()
		w.Header().Set("Content-Type", "application/json")
		if exists {
			json.NewEncoder(w).Encode(map[string]interface{}{"pane_id": paneID, "port": inst.Port, "running": true})
		} else {
			json.NewEncoder(w).Encode(map[string]interface{}{"pane_id": paneID, "running": false})
		}
	})))

	// Pane CRUD (must be after more specific /api/tmux/panes routes)
	http.HandleFunc("/api/tmux/panes/", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		path := strings.TrimPrefix(r.URL.Path, "/api/tmux/panes/")
		if strings.HasSuffix(path, "/restart") && r.Method == "POST" {
			handleRestartPane(w, r)
		} else if strings.HasSuffix(path, "/choose-session") || strings.HasSuffix(path, "/split") || strings.HasSuffix(path, "/unsplit") {
			// stub: return ok
			w.Header().Set("Content-Type", "application/json")
			json.NewEncoder(w).Encode(map[string]interface{}{"status": "ok"})
		} else if r.Method == "DELETE" {
			handleDeletePane(w, r)
		} else if r.Method == "GET" {
			handleGetPane(w, r)
		} else if r.Method == "PATCH" {
			handleUpdatePane(w, r)
		} else {
			http.Error(w, "not found", 404)
		}
	})))

	// Stub endpoints for frontend compatibility
	http.HandleFunc("/api/agents/", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		if r.Method == "GET" {
			json.NewEncoder(w).Encode(map[string]interface{}{"agents": []interface{}{}})
		} else {
			json.NewEncoder(w).Encode(map[string]interface{}{"status": "ok"})
		}
	})))
	http.HandleFunc("/api/settings/global", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{})
	})))
	http.HandleFunc("/api/auth/tokens", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"tokens": []interface{}{}})
	})))
	http.HandleFunc("/api/groups", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"groups": []interface{}{}})
	})))
	http.HandleFunc("/api/utils/file/exists", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		path := r.URL.Query().Get("path")
		_, err := os.Stat(path)
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"exists": err == nil})
	})))
	http.HandleFunc("/api/correctEnglish", corsMiddleware(authMiddleware(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{"success": false, "error": "not implemented"})
	})))

	// WebSocket proxy
	http.HandleFunc("/api/ws/", corsMiddleware(authMiddleware(handleWSProxy)))

	// Chat V2 — real-time event bus
	http.HandleFunc("/api/chat/send", corsMiddleware(authMiddleware(handleChatV2Send)))
	http.HandleFunc("/api/chat/webhook", corsMiddleware(handleChatV2Webhook))
	http.HandleFunc("/api/chat/stream", corsMiddleware(func(w http.ResponseWriter, r *http.Request) {
		t := r.URL.Query().Get("token")
		if t == "" || !verifyToken(t) {
			http.Error(w, "Not authenticated", 401)
			return
		}
		handleChatV2SSE(w, r)
	}))

	port := os.Getenv("PORT")
	if port == "" {
		port = "14444"
	}

	log.Printf("ttyd-manager starting on :%s", port)
	log.Fatal(http.ListenAndServe(":"+port, nil))
}

// ============================================================
// Chat V2 — Real-time EventBus
// ============================================================

type chatEvent struct {
	Type string      `json:"type"`
	Data interface{} `json:"data,omitempty"`
}

type chatBusT struct {
	mu      sync.RWMutex
	clients map[string]map[chan chatEvent]struct{}
}

var chatBus = &chatBusT{clients: make(map[string]map[chan chatEvent]struct{})}

func (b *chatBusT) subscribe(pane string) chan chatEvent {
	b.mu.Lock()
	defer b.mu.Unlock()
	ch := make(chan chatEvent, 64)
	if b.clients[pane] == nil {
		b.clients[pane] = make(map[chan chatEvent]struct{})
	}
	b.clients[pane][ch] = struct{}{}
	return ch
}

func (b *chatBusT) unsubscribe(pane string, ch chan chatEvent) {
	b.mu.Lock()
	defer b.mu.Unlock()
	if m, ok := b.clients[pane]; ok {
		delete(m, ch)
		if len(m) == 0 {
			delete(b.clients, pane)
		}
	}
	close(ch)
}

func (b *chatBusT) publish(pane string, evt chatEvent) {
	b.mu.RLock()
	defer b.mu.RUnlock()
	for ch := range b.clients[pane] {
		select {
		case ch <- evt:
		default:
		}
	}
}

func handleChatV2Send(w http.ResponseWriter, r *http.Request) {
	var req struct {
		Pane string `json:"pane"`
		Text string `json:"text"`
	}
	if json.NewDecoder(r.Body).Decode(&req) != nil || req.Pane == "" || req.Text == "" {
		http.Error(w, `{"error":"pane and text required"}`, 400)
		return
	}
	pane := req.Pane
	if !strings.Contains(pane, ":") {
		pane += ":main.0"
	}
	// Send to tmux
	text := strings.ReplaceAll(req.Text, "'", "'\\''")
	exec.Command("tmux", "send-keys", "-t", pane, "-l", text).Run()
	time.Sleep(50 * time.Millisecond)
	exec.Command("tmux", "send-keys", "-t", pane, "Enter").Run()

	id := fmt.Sprintf("msg_%d", time.Now().UnixMilli())
	short := strings.Replace(req.Pane, ":main.0", "", 1)

	chatBus.publish(short, chatEvent{Type: "user_message", Data: map[string]interface{}{"id": id, "text": req.Text, "ts": time.Now().Unix()}})
	chatBus.publish(short, chatEvent{Type: "status_change", Data: map[string]interface{}{"status": "thinking"}})

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{"ok": true, "id": id})
}

func handleChatV2Webhook(w http.ResponseWriter, r *http.Request) {
	var req struct {
		Pane  string      `json:"pane"`
		Event string      `json:"event"`
		Data  interface{} `json:"data"`
	}
	if json.NewDecoder(r.Body).Decode(&req) != nil || req.Pane == "" || req.Event == "" {
		http.Error(w, `{"error":"pane and event required"}`, 400)
		return
	}
	chatBus.publish(req.Pane, chatEvent{Type: req.Event, Data: req.Data})
	if req.Event == "ai_done" {
		chatBus.publish(req.Pane, chatEvent{Type: "status_change", Data: map[string]interface{}{"status": "idle"}})
	}
	w.WriteHeader(204)
}

func handleChatV2SSE(w http.ResponseWriter, r *http.Request) {
	pane := r.URL.Query().Get("pane")
	if pane == "" {
		http.Error(w, "pane required", 400)
		return
	}
	w.Header().Set("Content-Type", "text/event-stream")
	w.Header().Set("Cache-Control", "no-cache")
	w.Header().Set("Connection", "keep-alive")
	flusher, ok := w.(http.Flusher)
	if !ok {
		http.Error(w, "streaming not supported", 500)
		return
	}

	// Send connected event
	b, _ := json.Marshal(chatEvent{Type: "connected", Data: map[string]interface{}{"pane": pane}})
	fmt.Fprintf(w, "data: %s\n\n", b)
	flusher.Flush()

	ch := chatBus.subscribe(pane)
	defer chatBus.unsubscribe(pane, ch)

	for {
		select {
		case <-r.Context().Done():
			return
		case evt, ok := <-ch:
			if !ok {
				return
			}
			b, _ := json.Marshal(evt)
			fmt.Fprintf(w, "data: %s\n\n", b)
			flusher.Flush()
		}
	}
}
