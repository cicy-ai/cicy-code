FROM ubuntu:22.04

# 最小环境，只装包管理工具
RUN apt-get update && apt-get install -y \
    curl wget sudo \
    && rm -rf /var/lib/apt/lists/*

# 创建用户并给 sudo 权限
RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers
USER testuser
WORKDIR /home/testuser

# 复制二进制并设置权限
COPY --chown=testuser:testuser cicy-code-linux /home/testuser/cicy-code
RUN chmod +x /home/testuser/cicy-code

EXPOSE 18008
CMD ["./cicy-code"]
