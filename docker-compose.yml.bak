services:
  backend:
    build: ./api
    ports:
      - "14444:14444"
    environment:
      - MYSQL_DSN=root:cicy@tcp(mysql:3306)/ai_workers
      - PORT=14444
    depends_on:
      mysql:
        condition: service_healthy
    restart: unless-stopped

  ide:
    build: ./ide
    ports:
      - "8080:80"
    depends_on:
      - backend
    restart: unless-stopped

  ide-dev:
    image: node:20-alpine
    working_dir: /app
    volumes:
      - ./ide:/app
      - ide_modules:/app/node_modules
    ports:
      - "6903:6902"
    command: sh -c "npm install && npm run dev"
    environment:
      - CHOKIDAR_USEPOLLING=true
    profiles:
      - dev

  mysql:
    image: mysql:8
    environment:
      - MYSQL_ROOT_PASSWORD=cicy
      - MYSQL_DATABASE=ai_workers
    volumes:
      - mysql_data:/var/lib/mysql
    ports:
      - "3307:3306"
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      retries: 10
    restart: unless-stopped

volumes:
  mysql_data:
  ide_modules:
