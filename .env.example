# CiCy Code 统一配置 — 所有端口和地址的唯一来源
# 复制为 .env 后修改: cp .env.example .env
# 修改后需要: docker compose up -d && sudo supervisorctl restart cicy-api

# ── MySQL ──
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=cicy_code
MYSQL_PORT=3306

# ── Redis ──
REDIS_PORT=6379

# ── API ──
API_PORT=8008

# ── 前端 ──
NGINX_PORT=8000
VITE_PORT=8001

# ── code-server ──
CODE_SERVER_PORT=8002

# ── mitmproxy ──
MITMPROXY_PORT=8003

# ── 系统 ──
HOST_HOME=/home/your_user
HOST_UID=1000
HOST_GID=1000
